# Meliora 管理后台环境变量
# 复制为 .env(本地)或在部署平台的 Dashboard 配置
#
# 首次部署后访问 /admin,会进入 /setup 页面设置管理员密码
# 无需在此预设密码

# GitHub Personal Access Token(必填)
# 在 https://github.com/settings/tokens 创建 fine-grained token
# Repository access: 选中本仓库
# Permissions: Contents Read and write + Actions Write
# 如果使用 classic token,可使用 repo 权限
# 仅用于:GitHub 仓库配置读写、文件上传、触发更新 workflow、查询更新状态
# 可独立轮换,不影响已加密的配置与已签发的 Cookie
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 仓库标识(owner/repo 格式,必填)
GH_REPO=abloom25/Meliora

# 配置加密密钥(必填):用于配置文件加密(AES-GCM 256)与 Cookie 签名密钥派生(HMAC-SHA256),
# 与 GH_TOKEN 完全解耦。必须为 32 位以上随机字符串,生产模式校验强度(拒绝弱模式)。
# 生成示例:node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONFIG_ENCRYPTION_KEY=

# 目标分支(可选,默认 main)
GH_BRANCH=main

# 可选: GitHub 代理,用于检查更新和 workflow 内同步上游代码
# 触发 workflow dispatch 和查询 Actions 状态仍要求部署环境可访问 api.github.com
# 必须是公网 http(s) URL,不能指向 localhost、内网或云元数据地址
# 支持前缀形式: https://gh-proxy.example.com/
# 也支持模板形式: https://proxy.example.com?url={url}
GITHUB_PROXY=

# 可选: 禁用管理后台(设为 true/1/yes/on,大小写不敏感;/admin 显示"已禁用",除状态探针外所有 /api/* 返回 403)
ADMIN_DISABLED=
